# Pravaah OS — Backend Environment Variables (v2)
# Copy this file to .env in the project root and fill in real values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Required — fill these in before running
# ---------------------------------------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# Authentication (v2)
# ---------------------------------------------------------------------------
# Secret key for signing JWTs (must be long and random in production)
JWT_SECRET_KEY=change-me-to-another-long-random-string

# Token required to access /admin/rq (leave blank to disable protection)
ADMIN_TOKEN=

# ---------------------------------------------------------------------------
# Redis (v2)
# ---------------------------------------------------------------------------
# Redis URL for rate limiting, job queuing, and pub/sub
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite (default) — relative or absolute path:
DATABASE_PATH=./pravaah.db

# PostgreSQL (v2 optional) — overrides DATABASE_PATH when set:
# DATABASE_URL=postgresql://user:password@localhost:5432/pravaah

# ---------------------------------------------------------------------------
# ChromaDB vector store (v2)
# ---------------------------------------------------------------------------
CHROMA_PATH=./chroma_db

# ---------------------------------------------------------------------------
# Embedding model (v2)
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# File uploads
# ---------------------------------------------------------------------------
UPLOAD_FOLDER=./uploads

# Maximum upload file size in MB (v2 default: 200)
MAX_UPLOAD_MB=200

# ---------------------------------------------------------------------------
# Flask / SocketIO
# ---------------------------------------------------------------------------
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Comma-separated CORS allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# Deepgram model overrides
# ---------------------------------------------------------------------------
DEEPGRAM_STT_MODEL=nova-2
DEEPGRAM_TTS_MODEL=aura-asteria-en

# ---------------------------------------------------------------------------
# OpenRouter model overrides
# ---------------------------------------------------------------------------
OPENROUTER_HEAVY_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_LIGHT_MODEL=anthropic/claude-haiku-4-5-20251001

# ---------------------------------------------------------------------------
# Python logging level: DEBUG | INFO | WARNING | ERROR
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
