# Pravaah OS v2 — Environment Variables
# Copy this file to .env and fill in the values before running.
# cp .env.example .env

# ── Deepgram ──────────────────────────────────────────
DEEPGRAM_API_KEY=           # https://console.deepgram.com → API Keys (free tier: 200 min/month)

# ── OpenRouter ────────────────────────────────────────
OPENROUTER_API_KEY=         # https://openrouter.ai/keys (free tier available)
OPENROUTER_HEAVY_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_LIGHT_MODEL=anthropic/claude-haiku-4-5-20251001
EMBEDDING_MODEL=openai/text-embedding-3-small

# ── Flask ─────────────────────────────────────────────
FLASK_SECRET_KEY=           # generate: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ── Supabase (primary database) ───────────────────────
# Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Dashboard → Project Settings → Database → Connection string → URI
# Use the "Session mode" URI (port 5432) — NOT the pooler (6543).
# SQLAlchemy handles pooling via NullPool; the Supabase pgbouncer sits above that.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ChromaDB ──────────────────────────────────────────
CHROMA_PATH=./chroma_store

# ── Auth ──────────────────────────────────────────────
JWT_SECRET_KEY=             # generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=                # protect /admin/rq — any strong password

# ── File Upload ───────────────────────────────────────
UPLOAD_FOLDER=./uploads
MAX_UPLOAD_MB=200

# ── Frontend ──────────────────────────────────────────
VITE_API_URL=http://localhost:5000
VITE_WS_URL=http://localhost:5000

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
